rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(siteId) { return request.auth.uid == siteId; }
    function isShared(siteId) {
      return request.auth.token.email in resource.data.sharedEmails;
    }
    function isSharedDoc(siteId) {
      return request.auth.token.email in
        get(/databases/$(database)/documents/sites/$(siteId)).data.sharedEmails;
    }
    match /sites/{siteId} {
      allow read: if request.auth != null && (isOwner(siteId) || isShared(siteId));
      allow create: if request.auth != null && request.auth.uid == siteId;
      allow update: if request.auth != null && isOwner(siteId);
    }
    match /sites/{siteId}/{col}/{doc=**} {
      allow read, write: if request.auth != null && col != "workHours" && col != "tasks" &&
        (isOwner(siteId) || isSharedDoc(siteId));
    }
    match /sites/{siteId}/tasks/{taskId} {
      allow create: if request.auth != null && (isOwner(siteId) || isSharedDoc(siteId)) &&
        request.resource.data.ownerUid == request.auth.uid;
      allow read: if request.auth != null && (isOwner(siteId) || isSharedDoc(siteId)) &&
        (resource.data.ownerUid == request.auth.uid || resource.data.shared == true);
      allow update, delete: if request.auth != null && (isOwner(siteId) || isSharedDoc(siteId)) &&
        resource.data.ownerUid == request.auth.uid;
    }
    match /sites/{siteId}/workHours/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid &&
        (isOwner(siteId) || isSharedDoc(siteId));
    }
    match /sites/{siteId}/workHours/{uid}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == uid &&
        (isOwner(siteId) || isSharedDoc(siteId));
    }
  }
}
